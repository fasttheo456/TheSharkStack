---
import Base from "../../layouts/Base.astro";
import Newsletter from "../../components/Newsletter.astro";
import { tagColor } from "../../data/articleTags";
import { categories } from "../../data/categories";
import { getCollection } from "astro:content";

const articles = (
  await getCollection("articles", ({ data }) => !data.draft)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<Base
  title="Resources"
  description="Guides, explainers, and articles to help you choose and get the most from B2B sales SaaS."
>
  <section class="border-b border-ink-100 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h1 class="text-4xl font-semibold text-ink-900 sm:text-5xl">Resources</h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        Guides, explainers, and articles to help you choose the right sales
        tools, and get more out of the ones you have.
      </p>
    </div>
  </section>

  <!-- Articles -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-semibold text-ink-900">Latest articles</h2>

    {
      articles.length === 0 ? (
        <div class="mt-8 rounded-2xl border border-dashed border-ink-200 bg-white p-12 text-center">
          <p class="font-medium text-ink-700">No articles yet.</p>
          <p class="mt-1 text-sm text-ink-400">
            Articles added to the Resources collection will appear here.
          </p>
        </div>
      ) : (
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {articles.map((a) => (
            <a
              href={`/resources/${a.id}`}
              class="group flex flex-col rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
            >
              <div class="flex items-center justify-between">
                <span
                  class={`w-fit rounded-full px-3 py-1 text-xs font-semibold ${tagColor(a.data.tag)}`}
                >
                  {a.data.tag}
                </span>
                <span class="text-xs text-ink-400">{fmtDate(a.data.date)}</span>
              </div>
              <h3 class="mt-4 text-lg font-semibold text-ink-900 group-hover:text-brand-700">
                {a.data.title}
              </h3>
              <p class="mt-2 flex-1 text-sm text-ink-500">
                {a.data.description}
              </p>
              <span class="mt-4 text-sm font-medium text-brand-600">
                Read more &rarr;
              </span>
            </a>
          ))}
        </div>
      )
    }
  </section>

  <!-- Category jump-off -->
  <section class="border-t border-ink-100 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="text-3xl font-semibold text-ink-900">Explore by category</h2>
      <p class="mt-2 text-ink-500">
        Jump straight into the tools that matter for your goal.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          categories.map((c) => (
            <a
              href={`/categories/${c.slug}`}
              class="rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:text-brand-700"
            >
              {c.name}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Newsletter />

  <!-- Submit CTA -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div
      class="flex flex-col items-start justify-between gap-6 rounded-2xl border border-ink-100 bg-white p-10 sm:flex-row sm:items-center"
    >
      <div>
        <h3 class="text-2xl font-semibold text-ink-900">
          Know a tool we're missing?
        </h3>
        <p class="mt-2 max-w-xl text-ink-500">
          Suggest a B2B sales SaaS product and we'll review it for the
          directory.
        </p>
      </div>
      <a
        href="/submit"
        class="inline-block flex-shrink-0 rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white transition hover:bg-brand-700"
      >
        Add your tool &rarr;
      </a>
    </div>
  </section>
</Base>
