---
import Base from "../../layouts/Base.astro";
import { tagColor } from "../../data/articleTags";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
---

<Base title={article.data.title} description={article.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <nav class="flex items-center gap-1.5 text-sm text-ink-400">
      <a href="/resources" class="hover:text-brand-600">Resources</a>
      <span>/</span>
      <span class="text-ink-600">{article.data.tag}</span>
    </nav>

    <header class="mt-6">
      <span
        class={`w-fit rounded-full px-3 py-1 text-xs font-semibold ${tagColor(article.data.tag)}`}
        >{article.data.tag}</span
      >
      <h1
        class="mt-4 text-4xl font-semibold leading-tight text-ink-900 sm:text-5xl"
      >
        {article.data.title}
      </h1>
      <p class="mt-4 text-lg text-ink-500">{article.data.description}</p>
      <p class="mt-5 text-sm text-ink-400">
        {article.data.author && <span>By {article.data.author} · </span>}
        {fmtDate(article.data.date)}
      </p>
    </header>

    <div
      class="prose prose-ink mt-10 max-w-none prose-headings:font-display prose-headings:font-semibold prose-a:text-brand-700 prose-a:font-medium"
    >
      <Content />
    </div>

    <div class="mt-12 border-t border-ink-100 pt-8">
      <a
        href="/resources"
        class="text-sm font-medium text-brand-600 hover:text-brand-700"
        >&larr; Back to all resources</a
      >
    </div>
  </article>
</Base>
