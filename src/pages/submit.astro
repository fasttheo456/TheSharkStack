---
import Base from "../layouts/Base.astro";
import { categories } from "../data/categories";
---

<Base
  title="Add your tool"
  description="Submit a B2B sales SaaS tool for inclusion in TheSharkStack directory."
>
  <section class="border-b border-ink-100 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <h1 class="text-4xl font-semibold text-ink-900 sm:text-5xl">
        Add your tool
      </h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        Submit a B2B sales SaaS product and we'll review it for inclusion in the
        directory. It's free, we just need a few details to get started.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <!-- Success state (hidden until submit) -->
    <div
      id="successCard"
      class="hidden rounded-2xl border border-emerald-200 bg-emerald-50 p-10 text-center"
    >
      <span
        class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-emerald-500 text-white"
      >
        <svg
          class="h-7 w-7"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          ><path
            d="M20 6 9 17l-5-5"
            stroke-linecap="round"
            stroke-linejoin="round"></path></svg
        >
      </span>
      <h2 class="mt-5 text-2xl font-semibold text-ink-900">
        Thanks, we got it!
      </h2>
      <p id="successName" class="mt-2 text-ink-600"></p>
      <p class="mt-1 text-sm text-ink-500">
        We review submissions weekly and will be in touch if we need anything.
      </p>
      <div class="mt-6 flex justify-center gap-3">
        <a
          href="/tools"
          class="rounded-xl border border-ink-200 bg-white px-5 py-2.5 font-semibold text-ink-700 hover:border-ink-300"
          >Browse tools</a
        >
        <button
          id="submitAnother"
          class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white hover:bg-brand-700"
          >Submit another</button
        >
      </div>
    </div>

    <!-- Form -->
    <form
      id="submitForm"
      class="rounded-2xl border border-ink-100 bg-white p-8 sm:p-10"
    >
      <div class="grid gap-6 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label for="toolName" class="block text-sm font-medium text-ink-800"
            >Tool name <span class="text-brand-600">*</span></label
          >
          <input
            id="toolName"
            name="toolName"
            type="text"
            required
            placeholder="e.g. Apollo.io"
            class="mt-2 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
          />
        </div>

        <div>
          <label for="website" class="block text-sm font-medium text-ink-800"
            >Website <span class="text-brand-600">*</span></label
          >
          <input
            id="website"
            name="website"
            type="url"
            required
            placeholder="https://…"
            class="mt-2 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
          />
        </div>

        <div>
          <label for="category" class="block text-sm font-medium text-ink-800"
            >Category <span class="text-brand-600">*</span></label
          >
          <select
            id="category"
            name="category"
            required
            class="mt-2 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
          >
            <option value="" disabled selected>Select a category…</option>
            {categories.map((c) => <option value={c.slug}>{c.name}</option>)}
          </select>
        </div>

        <div>
          <label for="yourName" class="block text-sm font-medium text-ink-800"
            >Your name</label
          >
          <input
            id="yourName"
            name="yourName"
            type="text"
            placeholder="Jane Doe"
            class="mt-2 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-ink-800"
            >Your email <span class="text-brand-600">*</span></label
          >
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="you@company.com"
            class="mt-2 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
          />
        </div>

        <div class="sm:col-span-2">
          <label
            for="description"
            class="block text-sm font-medium text-ink-800"
            >Short description <span class="text-brand-600">*</span></label
          >
          <textarea
            id="description"
            name="description"
            required
            rows="4"
            placeholder="In a sentence or two, what does the tool do and who is it for?"
            class="mt-2 w-full rounded-xl border border-ink-200 bg-white px-4 py-2.5 text-sm outline-none transition focus:border-brand-400 focus:ring-2 focus:ring-brand-100"
          ></textarea>
        </div>
      </div>

      <div class="mt-8 flex items-center justify-between gap-4">
        <p class="text-xs text-ink-400">
          Fields marked <span class="text-brand-600">*</span> are required.
        </p>
        <button
          type="submit"
          class="rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white shadow-sm transition hover:bg-brand-700"
        >
          Submit tool
        </button>
      </div>
    </form>
  </section>
</Base>

<script>
  const form = document.getElementById("submitForm") as HTMLFormElement;
  const success = document.getElementById("successCard") as HTMLElement;
  const successName = document.getElementById("successName") as HTMLElement;
  const again = document.getElementById("submitAnother") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;

    const data = Object.fromEntries(new FormData(form).entries());

    // --- Wire up a real backend here ---
    // This demo just confirms locally. To actually receive submissions, point the
    // form at a no-backend form service and replace the block below, e.g.:
    //
    // await fetch('https://formspree.io/f/XXXXXXXX', {
    // method: 'POST',
    // headers: { Accept: 'application/json' },
    // body: new FormData(form),
    // });
    //
    // (Formspree, Netlify Forms, Basin, and Web3Forms all work with a static site.)

    successName.textContent = `We've logged "${data.toolName}" for review.`;
    form.classList.add("hidden");
    success.classList.remove("hidden");
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  again.addEventListener("click", () => {
    form.reset();
    success.classList.add("hidden");
    form.classList.remove("hidden");
  });
</script>
