---
import Base from "../../layouts/Base.astro";
import { Icon } from "astro-icon/components";
import ToolCard from "../../components/ToolCard.astro";
import ToolBadge from "../../components/ToolBadge.astro";
import Newsletter from "../../components/Newsletter.astro";
import { categories, categoryBySlug } from "../../data/categories";
import { toolsInCategory, type Tool } from "../../data/tools";

export function getStaticPaths() {
  return categories.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const category = categoryBySlug(slug!)!;
const catTools = toolsInCategory(slug!).sort((a, b) => b.rating - a.rating);
const freeCount = catTools.filter((t) => t.features.freePlan).length;

// In-category head-to-head pairs (up to 4)
const pairs: [Tool, Tool][] = [];
for (let i = 0; i < catTools.length; i++) {
  for (let j = i + 1; j < catTools.length; j++) {
    pairs.push([catTools[i], catTools[j]]);
  }
}
const topPairs = pairs.slice(0, 4);

const considerations = [
  {
    title: "Start with the outcome",
    body: `Define the single result you need from a ${category.shortName.toLowerCase()} tool before comparing features, it keeps the shortlist honest.`,
  },
  {
    title: "Match features to your workflow",
    body: "A long feature list only matters if you will use it. Map each tool to how your team actually works day to day.",
  },
  {
    title: "Check pricing at your scale",
    body: "Entry prices can be misleading. Look at what the plan costs at the size you will be in a year, including any add-ons.",
  },
  {
    title: "Trial with real data",
    body: "A polished demo tells you little. Run a short trial with your own data before you commit.",
  },
];

const faqs = [
  {
    q: `How many ${category.name.toLowerCase()} tools does TheSharkStack cover?`,
    a: `We currently track ${catTools.length} ${category.name.toLowerCase()} ${catTools.length === 1 ? "tool" : "tools"}, each reviewed on the same criteria so you can compare them fairly.`,
  },
  {
    q: `What is the best ${category.name.toLowerCase()} tool?`,
    a: `There is no single best, it depends on your goals, budget, and team. Use our side-by-side comparisons to weigh the contenders against your needs.`,
  },
  {
    q: `Are there free ${category.name.toLowerCase()} tools?`,
    a:
      freeCount > 0
        ? `Yes, ${freeCount} of the ${category.name.toLowerCase()} tools we cover offer a free plan. Look for the “Free plan” label on each card.`
        : `Most tools in this category use paid or custom pricing, but several offer free trials so you can test before you buy.`,
  },
];
---

<Base title={`Best ${category.name} Tools`} description={category.description}>
  <section class="border-b border-ink-100 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <nav class="flex items-center gap-1.5 text-sm text-ink-400">
        <a href="/categories" class="hover:text-brand-600">Categories</a>
        <span>/</span>
        <span class="text-ink-600">{category.name}</span>
      </nav>
      <div class="mt-4 flex items-start gap-4">
        <span
          class="inline-flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-brand-600 text-white"
        >
          <Icon name={`lucide:${category.icon}`} class="h-7 w-7" />
        </span>
        <div>
          <h1
            class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl"
          >
            {category.name}
          </h1>
          <p class="mt-2 max-w-2xl text-ink-500">{category.description}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools grid -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-lg font-semibold text-ink-900">
      {catTools.length}
      {category.name} tools
    </h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {catTools.map((t) => <ToolCard tool={t} />)}
    </div>
  </section>

  <!-- In-category comparisons -->
  {
    topPairs.length > 0 && (
      <section class="border-y border-ink-100 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
          <h2 class="text-3xl font-semibold text-ink-900">
            Popular {category.shortName} comparisons
          </h2>
          <p class="mt-2 text-ink-500">
            See how the leading {category.name.toLowerCase()} tools stack up
            head-to-head.
          </p>
          <div class="mt-10 grid gap-6 sm:grid-cols-2">
            {topPairs.map(([a, b]) => (
              <a
                href={`/compare/${a.slug}-vs-${b.slug}`}
                class="group flex items-center justify-between rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
              >
                <div class="flex items-center gap-3">
                  <ToolBadge badge={a.badge} website={a.website} name={a.name} size="sm" />
                  <span class="text-xs font-bold text-ink-300">VS</span>
                  <ToolBadge badge={b.badge} website={b.website} name={b.name} size="sm" />
                </div>
                <div class="text-right">
                  <p class="text-sm font-semibold text-ink-900">
                    {a.name.split(" ")[0]} vs {b.name.split(" ")[0]}
                  </p>
                  <p class="text-xs text-brand-600 group-hover:underline">
                    Compare &rarr;
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Buyer's guide -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-semibold text-ink-900">
      What to look for in {category.name.toLowerCase()} software
    </h2>
    <div class="mt-10 grid gap-x-12 gap-y-8 sm:grid-cols-2">
      {
        considerations.map((c) => (
          <div>
            <h3 class="font-semibold text-ink-900">{c.title}</h3>
            <p class="mt-1.5 text-sm text-ink-500">{c.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-ink-100 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <h2 class="text-3xl font-semibold text-ink-900">
        Frequently asked questions
      </h2>
      <div class="mt-8 divide-y divide-ink-100">
        {
          faqs.map((f) => (
            <div class="py-5">
              <h3 class="font-semibold text-ink-900">{f.q}</h3>
              <p class="mt-2 text-ink-600">{f.a}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Newsletter />
</Base>
