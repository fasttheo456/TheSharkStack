---
import Base from "../layouts/Base.astro";
import { Icon } from "astro-icon/components";
import ToolCard from "../components/ToolCard.astro";
import ToolBadge from "../components/ToolBadge.astro";
import Newsletter from "../components/Newsletter.astro";
import Speckles from "../components/Speckles.astro";
import { tagColor } from "../data/articleTags";
import { categories } from "../data/categories";
import { tools, toolBySlug, toolsInCategory } from "../data/tools";
import { featuredComparisons } from "../data/comparisons";
import { getCollection } from "astro:content";

const featuredTools = [...tools]
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 6);

const latestArticles = (
  await getCollection("articles", ({ data }) => !data.draft)
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

// Decorative hero backdrop: brand-logo stickers kept in the top & bottom bands
// (above and below the headline) so they never sit on the text.
// Only brands that are actually in our directory, spread across the whole hero
// (top band, side margins, bottom band) so none sit on the headline text.
const heroLogoSpec = [
  { slug: "apollo", pos: "left-[10%] top-[11%]", rot: "-rotate-[8deg]" },
  { slug: "salesforce", pos: "left-[42%] top-[7%]", rot: "rotate-[6deg]" },
  { slug: "gong", pos: "left-[78%] top-[11%]", rot: "rotate-[7deg]" },
  { slug: "outreach", pos: "left-[5%] top-[46%]", rot: "rotate-[6deg]" },
  { slug: "aircall", pos: "left-[92%] top-[44%]", rot: "-rotate-[6deg]" },
  { slug: "hubspot-sales", pos: "left-[16%] top-[78%]", rot: "-rotate-[6deg]" },
  { slug: "calendly", pos: "left-[52%] top-[80%]", rot: "rotate-[7deg]" },
  { slug: "zoominfo", pos: "left-[86%] top-[76%]", rot: "-rotate-[7deg]" },
];
const decorLogos = heroLogoSpec.map((s) => {
  const t = toolBySlug(s.slug)!;
  let domain = "";
  try {
    domain = new URL(t.website).hostname.replace(/^www\./, "");
  } catch {}
  return { domain, name: t.name, pos: s.pos, rot: s.rot };
});

// Small "speckles" sprinkled across the whole hero (tiny, so text stays readable)
const freckles = [
  "left-[7%] top-[24%] h-2 w-2 bg-ink-200",
  "left-[28%] top-[16%] h-1.5 w-1.5 bg-ink-300",
  "left-[52%] top-[20%] h-1 w-1 bg-ink-300",
  "left-[73%] top-[15%] h-2 w-2 bg-ink-200",
  "left-[93%] top-[28%] h-1.5 w-1.5 bg-ink-300",
  "left-[10%] top-[48%] h-1 w-1 bg-ink-300",
  "left-[90%] top-[46%] h-1.5 w-1.5 bg-ink-300",
  "left-[5%] top-[64%] h-2 w-2 bg-ink-200",
  "left-[31%] top-[62%] h-1 w-1 bg-ink-300",
  "left-[55%] top-[64%] h-1.5 w-1.5 bg-ink-200",
  "left-[78%] top-[60%] h-1 w-1 bg-ink-300",
  "left-[20%] top-[86%] h-1.5 w-1.5 bg-ink-300",
  "left-[68%] top-[88%] h-1 w-1 bg-ink-300",
  "left-[48%] top-[90%] h-2 w-2 bg-ink-200",
];

// A couple of playful sticker accents
const stickers = [
  { icon: "sparkles", pos: "left-[34%] top-[16%]", cls: "h-5 w-5 -rotate-6 text-ink-300" },
  { icon: "star", pos: "left-[80%] top-[67%]", cls: "h-4 w-4 rotate-12 text-ink-300" },
  { icon: "plus", pos: "left-[8%] top-[52%]", cls: "h-4 w-4 text-ink-300" },
];
---

<Base
  title="TheSharkStack"
  description="Compare the best B2B sales SaaS tools side-by-side, features, pricing, ratings, and a searchable directory across prospecting, CRM, dialers, and conversation intelligence."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-ink-100">
    <div class="absolute inset-0 bg-dotted opacity-60"></div>
    <div
      class="absolute inset-0 bg-gradient-to-b from-ink-50/0 via-ink-50/40 to-ink-50"
    >
    </div>

    <!-- Decorative backdrop: brand stickers, speckles & accents (behind the text) -->
    <div
      class="pointer-events-none absolute inset-0"
      aria-hidden="true"
    >
      {
        freckles.map((f) => <span class={`absolute rounded-full ${f}`} />)
      }
      {
        stickers.map((s) => (
          <span class={`absolute ${s.pos}`}>
            <Icon name={`lucide:${s.icon}`} class={s.cls} />
          </span>
        ))
      }
      {
        decorLogos.map((l, i) => (
          <span
            class={`absolute ${l.pos} animate-floaty`}
            style={`animation-delay:${i * 0.5}s`}
          >
            <span
              class={`flex h-9 w-9 items-center justify-center overflow-hidden rounded-xl border border-ink-200 bg-white shadow-sm ${l.rot}`}
            >
              <img
                src={`https://icons.duckduckgo.com/ip3/${l.domain}.ico`}
                alt=""
                width="48"
                height="48"
                loading="lazy"
                class="h-5 w-5 object-contain"
              />
            </span>
          </span>
        ))
      }
    </div>

    <div
      class="relative mx-auto flex min-h-[calc(100svh-5rem)] max-w-6xl flex-col items-center justify-center px-4 py-16 text-center sm:px-6"
    >
      <h1
        class="mx-auto max-w-4xl text-5xl font-semibold leading-[1.04] text-ink-900 sm:text-7xl"
      >
        The directory for <span class="text-orange-600">sales</span> software
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-ink-500">
        Search, compare, and choose the right sales stack, with side-by-side
        comparisons of features, pricing, and ratings across {tools.length} tools.
      </p>

      <!-- Search block -->
      <form
        action="/tools"
        method="get"
        class="mx-auto mt-10 flex max-w-xl items-center gap-2 rounded-2xl border border-ink-200 bg-white p-2 shadow-sm focus-within:border-brand-400 focus-within:ring-4 focus-within:ring-brand-100"
      >
        <span class="pl-3 text-ink-400" aria-hidden="true">
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 21l-4.35-4.35M17 11a6 6 0 1 1-12 0 6 6 0 0 1 12 0Z"
            ></path>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          placeholder="Search for a tool, e.g. Apollo or CRM…"
          aria-label="Search tools"
          class="flex-1 bg-transparent px-1 py-2 text-base outline-none placeholder:text-ink-400"
        />
        <button
          type="submit"
          class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white transition hover:bg-brand-700"
        >
          Search
        </button>
      </form>
      <p class="mt-4 text-sm text-ink-400">
        Popular:
        {
          ["prospecting", "crm", "conversation-intelligence"].map((slug, i) => (
            <>
              {i > 0 && <span class="text-ink-300"> · </span>}
              <a
                href={`/categories/${slug}`}
                class="font-medium text-brand-600 hover:underline"
              >
                {categories.find((c) => c.slug === slug)?.shortName}
              </a>
            </>
          ))
        }
      </p>
    </div>
  </section>

  <!-- Top rated tools -->
  <section class="relative overflow-hidden border-y border-ink-100 bg-white">
    <Speckles />
    <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl font-semibold text-ink-900">
            Top-rated tools
          </h2>
          <p class="mt-2 text-ink-500">
            The highest-scoring platforms across all categories.
          </p>
        </div>
        <a
          href="/tools"
          class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
          >See all &rarr;</a
        >
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTools.map((t) => <ToolCard tool={t} />)}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold text-ink-900">
          Browse by category
        </h2>
        <p class="mt-2 text-ink-500">
          Every major slice of the modern sales stack.
        </p>
      </div>
      <a
        href="/categories"
        class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
        >All categories &rarr;</a
      >
    </div>
    <div class="mt-10 flex flex-wrap gap-3">
      {
        categories.map((c) => (
          <a
            href={`/categories/${c.slug}`}
            class="group inline-flex items-center gap-2.5 rounded-full border border-ink-200 bg-white py-2 pl-2.5 pr-4 transition hover:border-orange-300 hover:bg-orange-50"
          >
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink-100 text-ink-700 transition group-hover:bg-orange-600 group-hover:text-white">
              <Icon name={`lucide:${c.icon}`} class="h-4 w-4" />
            </span>
            <span class="text-sm font-medium text-ink-900 group-hover:text-orange-700">
              {c.name}
            </span>
            <span class="text-xs font-medium text-ink-400">
              {toolsInCategory(c.slug).length}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Latest guides (articles) -->
  {
    latestArticles.length > 0 && (
      <section class="relative overflow-hidden border-y border-ink-100 bg-white">
        <Speckles />
        <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6">
          <div class="flex items-end justify-between">
            <div>
              <h2 class="text-3xl font-semibold text-ink-900">
                Latest articles
              </h2>
              <p class="mt-2 text-ink-500">
                Buying advice and comparisons from our editors.
              </p>
            </div>
            <a
              href="/resources"
              class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
            >
              All resources &rarr;
            </a>
          </div>
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {latestArticles.map((a) => (
              <a
                href={`/resources/${a.id}`}
                class="group flex flex-col rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
              >
                <div class="flex items-center justify-between">
                  <span
                    class={`w-fit rounded-full px-3 py-1 text-xs font-semibold ${tagColor(a.data.tag)}`}
                  >
                    {a.data.tag}
                  </span>
                  <span class="text-xs text-ink-400">
                    {fmtDate(a.data.date)}
                  </span>
                </div>
                <h3 class="mt-4 text-lg font-semibold text-ink-900 group-hover:text-brand-700">
                  {a.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm text-ink-500">
                  {a.data.description}
                </p>
                <span class="mt-4 text-sm font-medium text-brand-600">
                  Read more &rarr;
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Featured comparisons -->
  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold text-ink-900">
          Popular head-to-heads
        </h2>
        <p class="mt-2 text-ink-500">The matchups sales teams research most.</p>
      </div>
      <a
        href="/compare"
        class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
        >All comparisons &rarr;</a
      >
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        featuredComparisons.map(([a, b]) => {
          const ta = toolBySlug(a)!;
          const tb = toolBySlug(b)!;
          return (
            <a
              href={`/compare/${a}-vs-${b}`}
              class="group flex items-center justify-between rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
            >
              <div class="flex items-center gap-3">
                <ToolBadge badge={ta.badge} website={ta.website} name={ta.name} size="sm" />
                <span class="text-xs font-bold text-ink-300">VS</span>
                <ToolBadge badge={tb.badge} website={tb.website} name={tb.name} size="sm" />
              </div>
              <div class="text-right">
                <p class="text-sm font-semibold text-ink-900">
                  {ta.name.split(" ")[0]} vs {tb.name.split(" ")[0]}
                </p>
                <p class="text-xs text-brand-600 group-hover:underline">
                  Compare &rarr;
                </p>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- Newsletter -->
  <Newsletter />

  <!-- Submit a tool CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-28 sm:px-6">
    <div
      class="flex flex-col items-start justify-between gap-6 rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 p-10 text-white sm:flex-row sm:items-center"
    >
      <div>
        <h3 class="text-2xl font-bold">Building a sales tool?</h3>
        <p class="mt-3 max-w-xl text-brand-100">
          Submit your product and we'll review it for inclusion in the
          directory, free.
        </p>
      </div>
      <a
        href="/submit"
        class="inline-block flex-shrink-0 rounded-xl bg-white px-6 py-3 font-semibold text-brand-700 transition hover:bg-ink-50"
      >
        Add your tool &rarr;
      </a>
    </div>
  </section>
</Base>
