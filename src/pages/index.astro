---
import Base from "../layouts/Base.astro";
import { Icon } from "astro-icon/components";
import ToolCard from "../components/ToolCard.astro";
import ToolBadge from "../components/ToolBadge.astro";
import Newsletter from "../components/Newsletter.astro";
import Speckles from "../components/Speckles.astro";
import { tagColor } from "../data/articleTags";
import { categories } from "../data/categories";
import { tools, toolBySlug, toolsInCategory } from "../data/tools";
import { featuredComparisons } from "../data/comparisons";
import { getCollection } from "astro:content";

const featuredTools = [...tools]
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 6);

const latestArticles = (
  await getCollection("articles", ({ data }) => !data.draft)
)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

// Category chips shown in the hero.
const chipCats = [
  "prospecting",
  "crm",
  "phone-system",
  "conversation-intelligence",
  "sales-engagement",
].map((s) => categories.find((c) => c.slug === s)!);

// A few well-known tools to show in the logo strip under the hero.
const logoStrip = [
  "salesforce",
  "hubspot-sales",
  "apollo",
  "gong",
  "pipedrive",
  "zoominfo",
  "aircall",
  "calendly",
].map((slug) => {
  const t = toolBySlug(slug)!;
  let domain = "";
  try {
    domain = new URL(t.website).hostname.replace(/^www\./, "");
  } catch {}
  return { domain, name: t.name, slug };
});
---

<Base
  title="TheSharkStack"
  description="Compare the best B2B sales SaaS tools side-by-side, features, pricing, ratings, and a searchable directory across prospecting, CRM, dialers, and conversation intelligence."
>
  <!-- Hero — dark poster -->
  <section class="relative overflow-hidden bg-ink-950 text-white">
    <!-- green halftone cluster, top-right -->
    <div
      class="pointer-events-none absolute right-0 top-0 h-[28rem] w-[28rem]"
      style="background-image:radial-gradient(var(--color-emerald-500) 2px, transparent 2.4px); background-size:18px 18px; -webkit-mask-image:radial-gradient(circle at 78% 22%, #000, transparent 66%); mask-image:radial-gradient(circle at 78% 22%, #000, transparent 66%); opacity:0.18;"
      aria-hidden="true"
    >
    </div>

    <div
      class="relative mx-auto flex min-h-[calc(100svh-5rem)] max-w-6xl flex-col justify-center px-4 py-20 sm:px-6"
    >
      <p
        class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald-400"
      >
        {tools.length} tools · {categories.length} categories
      </p>
      <h1 class="mt-5 max-w-4xl text-6xl leading-[0.98] text-white sm:text-8xl">
        The directory for <span class="text-emerald-400">sales</span> software
      </h1>
      <p class="mt-6 max-w-xl text-lg text-ink-300">
        Search, compare, and choose the right sales stack, side by side across {
          tools.length
        } tools.
      </p>

      <!-- Search -->
      <form
        action="/tools"
        method="get"
        class="mt-9 flex w-full max-w-xl items-center gap-2"
      >
        <div
          class="flex flex-1 items-center gap-2 rounded-xl border-2 border-emerald-500 bg-white px-3"
        >
          <span class="text-ink-400" aria-hidden="true">
            <svg
              class="h-5 w-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 21l-4.35-4.35M17 11a6 6 0 1 1-12 0 6 6 0 0 1 12 0Z"
              ></path>
            </svg>
          </span>
          <input
            type="search"
            name="q"
            placeholder="Search 20+ sales tools…"
            aria-label="Search tools"
            class="flex-1 bg-transparent py-3 text-base text-ink-900 outline-none placeholder:text-ink-400"
          />
        </div>
        <button
          type="submit"
          class="rounded-xl border-2 border-emerald-500 bg-emerald-500 px-6 py-3 font-bold text-ink-900 transition hover:bg-emerald-400"
        >
          Hunt
        </button>
      </form>

      <!-- Category chips -->
      <div class="mt-6 flex flex-wrap gap-2">
        {
          chipCats.map((c, i) => (
            <a
              href={`/categories/${c.slug}`}
              class={
                i === 0
                  ? "rounded-full bg-emerald-500 px-4 py-1.5 text-sm font-semibold text-ink-900"
                  : "rounded-full border border-ink-700 px-4 py-1.5 text-sm font-medium text-ink-200 transition hover:border-emerald-500 hover:text-white"
              }
            >
              {c.shortName}
            </a>
          ))
        }
      </div>

      <!-- Logo strip -->
      <div class="mt-12 flex flex-col gap-3">
        <p class="text-[11px] font-medium uppercase tracking-wider text-ink-400">
          A few of the {tools.length} tools we compare
        </p>
        <div class="flex flex-wrap items-center gap-2.5">
          {
            logoStrip.map((l) => (
              <a
                href={`/tools/${l.slug}`}
                title={l.name}
                class="flex h-8 w-8 items-center justify-center rounded-lg bg-white/95 transition hover:bg-white"
              >
                <img
                  src={`https://icons.duckduckgo.com/ip3/${l.domain}.ico`}
                  alt={l.name}
                  width="32"
                  height="32"
                  loading="lazy"
                  class="h-5 w-5 object-contain"
                />
              </a>
            ))
          }
          <a
            href="/tools"
            class="ml-1 text-xs font-semibold text-emerald-400 transition hover:text-emerald-300"
          >
            +{tools.length - logoStrip.length} more &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Top rated tools -->
  <section class="relative overflow-hidden border-y border-ink-100 bg-white">
    <Speckles />
    <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-3xl font-semibold text-ink-900">
            Top-rated tools
          </h2>
          <p class="mt-2 text-ink-500">
            The highest-scoring platforms across all categories.
          </p>
        </div>
        <a
          href="/tools"
          class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
          >See all &rarr;</a
        >
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTools.map((t) => <ToolCard tool={t} />)}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold text-ink-900">
          Browse by category
        </h2>
        <p class="mt-2 text-ink-500">
          Every major slice of the modern sales stack.
        </p>
      </div>
      <a
        href="/categories"
        class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
        >All categories &rarr;</a
      >
    </div>
    <div class="mt-10 flex flex-wrap gap-3">
      {
        categories.map((c) => (
          <a
            href={`/categories/${c.slug}`}
            class="group inline-flex items-center gap-2.5 rounded-full border border-ink-200 bg-white py-2 pl-2.5 pr-4 transition hover:border-orange-300 hover:bg-orange-50"
          >
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-ink-100 text-ink-700 transition group-hover:bg-orange-600 group-hover:text-white">
              <Icon name={`lucide:${c.icon}`} class="h-4 w-4" />
            </span>
            <span class="text-sm font-medium text-ink-900 group-hover:text-orange-700">
              {c.name}
            </span>
            <span class="text-xs font-medium text-ink-400">
              {toolsInCategory(c.slug).length}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Latest guides (articles) -->
  {
    latestArticles.length > 0 && (
      <section class="relative overflow-hidden border-y border-ink-100 bg-white">
        <Speckles />
        <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6">
          <div class="flex items-end justify-between">
            <div>
              <h2 class="text-3xl font-semibold text-ink-900">
                Latest articles
              </h2>
              <p class="mt-2 text-ink-500">
                Buying advice and comparisons from our editors.
              </p>
            </div>
            <a
              href="/resources"
              class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
            >
              All resources &rarr;
            </a>
          </div>
          <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {latestArticles.map((a) => (
              <a
                href={`/resources/${a.id}`}
                class="group flex flex-col rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
              >
                <div class="flex items-center justify-between">
                  <span
                    class={`w-fit rounded-full px-3 py-1 text-xs font-semibold ${tagColor(a.data.tag)}`}
                  >
                    {a.data.tag}
                  </span>
                  <span class="text-xs text-ink-400">
                    {fmtDate(a.data.date)}
                  </span>
                </div>
                <h3 class="mt-4 text-lg font-semibold text-ink-900 group-hover:text-brand-700">
                  {a.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm text-ink-500">
                  {a.data.description}
                </p>
                <span class="mt-4 text-sm font-medium text-brand-600">
                  Read more &rarr;
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Featured comparisons -->
  <section class="mx-auto max-w-6xl px-4 py-24 sm:px-6">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-3xl font-semibold text-ink-900">
          Popular head-to-heads
        </h2>
        <p class="mt-2 text-ink-500">The matchups sales teams research most.</p>
      </div>
      <a
        href="/compare"
        class="hidden text-sm font-medium text-brand-600 hover:text-brand-700 sm:block"
        >All comparisons &rarr;</a
      >
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        featuredComparisons.map(([a, b]) => {
          const ta = toolBySlug(a)!;
          const tb = toolBySlug(b)!;
          return (
            <a
              href={`/compare/${a}-vs-${b}`}
              class="group flex items-center justify-between rounded-2xl border border-ink-100 bg-white p-6 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
            >
              <div class="flex items-center gap-3">
                <ToolBadge badge={ta.badge} website={ta.website} name={ta.name} size="sm" />
                <span class="text-xs font-bold text-ink-300">VS</span>
                <ToolBadge badge={tb.badge} website={tb.website} name={tb.name} size="sm" />
              </div>
              <div class="text-right">
                <p class="text-sm font-semibold text-ink-900">
                  {ta.name.split(" ")[0]} vs {tb.name.split(" ")[0]}
                </p>
                <p class="text-xs text-brand-600 group-hover:underline">
                  Compare &rarr;
                </p>
              </div>
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- Newsletter -->
  <Newsletter />

  <!-- Submit a tool CTA -->
  <section class="mx-auto max-w-6xl px-4 pb-28 sm:px-6">
    <div
      class="flex flex-col items-start justify-between gap-6 rounded-2xl bg-gradient-to-br from-brand-600 to-brand-800 p-10 text-white sm:flex-row sm:items-center"
    >
      <div>
        <h3 class="text-2xl font-bold">Building a sales tool?</h3>
        <p class="mt-3 max-w-xl text-brand-100">
          Submit your product and we'll review it for inclusion in the
          directory, free.
        </p>
      </div>
      <a
        href="/submit"
        class="inline-block flex-shrink-0 rounded-xl border-2 border-white bg-orange-500 px-6 py-3 font-bold text-ink-900 shadow-[3px_3px_0_0_#ffffff] transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:bg-orange-400"
      >
        Add your tool &rarr;
      </a>
    </div>
  </section>
</Base>
