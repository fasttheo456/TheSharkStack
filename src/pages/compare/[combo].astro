---
import Base from "../../layouts/Base.astro";
import Rating from "../../components/Rating.astro";
import ToolBadge from "../../components/ToolBadge.astro";
import {
  tools,
  toolBySlug,
  featuresForCategory,
  sharedCategory,
  categoryName,
  formatStartingPrice,
  budgetLabel,
  complexityLabel,
  type Tool,
} from "../../data/tools";

export function getStaticPaths() {
  const paths = [];
  for (const a of tools) {
    for (const b of tools) {
      if (a.slug === b.slug) continue;
      // Only generate comparisons between tools that share a category.
      const sameCategory = a.categories.some((c) => b.categories.includes(c));
      if (!sameCategory) continue;
      paths.push({ params: { combo: `${a.slug}-vs-${b.slug}` } });
    }
  }
  return paths;
}

const { combo } = Astro.params;
const [aSlug, bSlug] = combo!.split("-vs-");
const a = toolBySlug(aSlug)!;
const b = toolBySlug(bSlug)!;

// Feature set for the category these two tools share
const catFeatures = featuresForCategory(sharedCategory(a, b));
const featureCount = (t: Tool) =>
  catFeatures.filter((f) => t.features[f.key]).length;
const winner = a.rating === b.rating ? null : a.rating > b.rating ? a : b;

const specs: { label: string; a: string; b: string }[] = [
  {
    label: "Editorial rating",
    a: `${a.rating.toFixed(1)} / 5`,
    b: `${b.rating.toFixed(1)} / 5`,
  },
  {
    label: "Starting price",
    a: formatStartingPrice(a),
    b: formatStartingPrice(b),
  },
  {
    label: "Budget tier",
    a: budgetLabel[a.budgetTier],
    b: budgetLabel[b.budgetTier],
  },
  {
    label: "Complexity",
    a: complexityLabel[a.complexity],
    b: complexityLabel[b.complexity],
  },
  {
    label: "Primary category",
    a: categoryName(a.primaryCategory),
    b: categoryName(b.primaryCategory),
  },
  {
    label: "Integrations",
    a: `${a.integrationsCount}+`,
    b: `${b.integrationsCount}+`,
  },
  { label: "Founded", a: String(a.founded), b: String(b.founded) },
];
---

<Base
  title={`${a.name} vs ${b.name}`}
  description={`${a.name} vs ${b.name}: compare features, pricing, ratings, and pros & cons side by side.`}
>
  <section class="mx-auto max-w-5xl px-4 pt-8 sm:px-6">
    <nav class="flex items-center gap-1.5 text-sm text-ink-400">
      <a href="/compare" class="hover:text-brand-600">Compare</a>
      <span>/</span>
      <span class="text-ink-600"
        >{a.name.split(" ")[0]} vs {b.name.split(" ")[0]}</span
      >
    </nav>

    <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
      {a.name}
      <span class="text-ink-300">vs</span>
      {b.name}
    </h1>
    <p class="mt-2 max-w-2xl text-ink-500">
      A side-by-side comparison of features, pricing, and ratings to help you
      choose.
    </p>
  </section>

  <!-- Head-to-head cards -->
  <section class="mx-auto max-w-5xl px-4 py-8 sm:px-6">
    <div class="grid gap-5 sm:grid-cols-2">
      {
        [a, b].map((t) => (
          <div
            class={`rounded-2xl border bg-white p-6 ${winner === t ? "border-ink-300" : "border-ink-100"}`}
          >
            {winner === t && (
              <span class="mb-3 inline-block rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-white">
                Higher rated
              </span>
            )}
            <div class="flex items-center gap-3">
              <ToolBadge badge={t.badge} website={t.website} name={t.name} size="lg" />
              <div>
                <h2 class="text-lg font-bold text-ink-900">{t.name}</h2>
                <p class="text-sm text-ink-400">{t.tagline}</p>
              </div>
            </div>
            <div class="mt-4">
              <Rating value={t.rating} count={t.reviewCount} size="md" />
            </div>
            <p class="mt-4 text-2xl font-bold text-ink-900">
              {formatStartingPrice(t)}
            </p>
            <p class="text-xs text-ink-400">{t.pricingNote}</p>
            <div class="mt-4 flex gap-2">
              <a
                href={`/tools/${t.slug}`}
                class="flex-1 rounded-lg border border-ink-200 px-4 py-2 text-center text-sm font-medium text-ink-700 hover:border-ink-300"
              >
                Full review
              </a>
              <a
                href={t.website}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="flex-1 rounded-lg bg-brand-600 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-brand-700"
              >
                Visit
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Specs table -->
  <section class="mx-auto max-w-5xl px-4 sm:px-6">
    <h2 class="text-xl font-bold text-ink-900">At a glance</h2>
    <div class="mt-4 overflow-hidden rounded-2xl border border-ink-100">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-ink-50 text-left text-ink-500">
            <th class="px-4 py-3 font-medium">Spec</th>
            <th class="px-4 py-3 font-semibold text-ink-900"
              >{a.name.split(" ")[0]}</th
            >
            <th class="px-4 py-3 font-semibold text-ink-900"
              >{b.name.split(" ")[0]}</th
            >
          </tr>
        </thead>
        <tbody>
          {
            specs.map((s, i) => (
              <tr class={i % 2 ? "bg-ink-50/40" : "bg-white"}>
                <td class="px-4 py-3 text-ink-500">{s.label}</td>
                <td class="px-4 py-3 font-medium text-ink-900">{s.a}</td>
                <td class="px-4 py-3 font-medium text-ink-900">{s.b}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <h2 class="text-xl font-bold text-ink-900">Feature comparison</h2>
    <p class="mt-1 text-sm text-ink-400">
      {a.name.split(" ")[0]} offers {featureCount(a)} of {catFeatures.length} tracked
      {categoryName(sharedCategory(a, b)).toLowerCase()} features;
      {b.name.split(" ")[0]} offers {featureCount(b)}.
    </p>
    <div class="mt-4 overflow-hidden rounded-2xl border border-ink-100">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-ink-50 text-left text-ink-500">
            <th class="px-4 py-3 font-medium">Feature</th>
            <th class="px-4 py-3 text-center font-semibold text-ink-900"
              >{a.name.split(" ")[0]}</th
            >
            <th class="px-4 py-3 text-center font-semibold text-ink-900"
              >{b.name.split(" ")[0]}</th
            >
          </tr>
        </thead>
        <tbody>
          {
            catFeatures.map((f, i) => (
              <tr class={i % 2 ? "bg-ink-50/40" : "bg-white"}>
                <td class="px-4 py-3 text-ink-700">{f.label}</td>
                {[a, b].map((t) => (
                  <td class="px-4 py-3 text-center">
                    {t.features[f.key] ? (
                      <svg
                        class="mx-auto h-5 w-5 text-emerald-500"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.4"
                      >
                        <path
                          d="M20 6 9 17l-5-5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    ) : (
                      <svg
                        class="mx-auto h-5 w-5 text-ink-300"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                      >
                        <path
                          d="M18 6 6 18M6 6l12 12"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    )}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- Pros/cons -->
  <section class="mx-auto max-w-5xl px-4 pb-10 sm:px-6">
    <div class="grid gap-5 sm:grid-cols-2">
      {
        [a, b].map((t) => (
          <div class="rounded-2xl border border-ink-100 p-6">
            <div class="flex items-center gap-3">
              <ToolBadge badge={t.badge} website={t.website} name={t.name} size="sm" />
              <h3 class="font-bold text-ink-900">{t.name}</h3>
            </div>
            <p class="mt-3 text-sm font-semibold text-emerald-700">Pros</p>
            <ul class="mt-2 space-y-1.5">
              {t.pros.map((p) => (
                <li class="flex gap-2 text-sm text-ink-600">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-emerald-500" />
                  {p}
                </li>
              ))}
            </ul>
            <p class="mt-4 text-sm font-semibold text-rose-600">Cons</p>
            <ul class="mt-2 space-y-1.5">
              {t.cons.map((c) => (
                <li class="flex gap-2 text-sm text-ink-600">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-rose-400" />
                  {c}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Verdict -->
  <section class="mx-auto max-w-5xl px-4 pb-20 sm:px-6">
    <div
      class="rounded-2xl bg-gradient-to-br from-ink-900 to-ink-800 p-8 text-white"
    >
      <h2 class="text-xl font-bold">The verdict</h2>
      <p class="mt-3 max-w-3xl text-ink-200">
        {
          winner
            ? `${winner.name} edges ahead on our editorial score, but the right pick depends on your priorities. Choose ${a.name.split(" ")[0]} if you value ${a.bestFor.toLowerCase()} Choose ${b.name.split(" ")[0]} if you need ${b.bestFor.toLowerCase()}`
            : `These two are evenly matched on our score. Choose ${a.name.split(" ")[0]} if you value ${a.bestFor.toLowerCase()} Choose ${b.name.split(" ")[0]} if you need ${b.bestFor.toLowerCase()}`
        }
      </p>
      <a
        href="/tools"
        class="mt-5 inline-block rounded-xl bg-white px-5 py-2.5 font-semibold text-ink-900 transition hover:bg-ink-100"
      >
        Browse all tools &rarr;
      </a>
    </div>
  </section>
</Base>
