---
import Base from "../layouts/Base.astro";
---

<Base title="Page not found">
  <section
    class="mx-auto flex max-w-xl flex-col items-center px-4 py-28 text-center sm:px-6"
  >
    <p class="text-6xl font-extrabold text-brand-600">404</p>
    <h1 class="mt-4 text-2xl font-bold text-ink-900">
      We couldn't find that page
    </h1>
    <p class="mt-2 text-ink-500">
      The page may have moved. Try one of these instead:
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-xl bg-brand-600 px-5 py-2.5 font-semibold text-white hover:bg-brand-700"
        >Home</a
      >
      <a
        href="/tools"
        class="rounded-xl border border-ink-200 px-5 py-2.5 font-semibold text-ink-700 hover:border-ink-300"
        >All tools</a
      >
      <a
        href="/compare"
        class="rounded-xl border border-ink-200 px-5 py-2.5 font-semibold text-ink-700 hover:border-ink-300"
        >Compare tools</a
      >
    </div>
  </section>
</Base>
