---
import Base from "../layouts/Base.astro";
---

<Base title="404 — lost at sea">
  <section class="relative overflow-hidden bg-ink-950 text-white">
    <div
      class="pointer-events-none absolute right-0 top-0 h-96 w-96"
      style="background-image:radial-gradient(var(--color-emerald-500) 2px, transparent 2.4px); background-size:18px 18px; -webkit-mask-image:radial-gradient(circle at 80% 20%, #000, transparent 66%); mask-image:radial-gradient(circle at 80% 20%, #000, transparent 66%); opacity:0.16;"
      aria-hidden="true"
    >
    </div>

    <div
      class="relative mx-auto flex min-h-[calc(100svh-5rem)] max-w-4xl flex-col items-center justify-center px-4 py-12 text-center sm:px-6"
    >
      <!-- 3D shark stage -->
      <div
        id="shark-stage"
        class="relative h-[300px] w-full max-w-2xl sm:h-[400px]"
      >
        <div
          id="shark-fallback"
          class="pointer-events-none absolute inset-0 flex items-center justify-center text-[140px] leading-none"
          aria-hidden="true"
        >
          🦈
        </div>
        <canvas id="shark-canvas" class="absolute inset-0 h-full w-full"></canvas>
      </div>

      <p class="mt-2 font-display text-7xl text-emerald-400 sm:text-8xl">404</p>
      <h1 class="mt-2 text-2xl text-white sm:text-3xl">This page got eaten</h1>
      <p class="mt-3 max-w-md text-ink-300">
        A shark swallowed the page you were after. Let's get you back to safer
        waters.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="rounded-xl border-2 border-emerald-500 bg-emerald-500 px-5 py-2.5 font-bold text-ink-900 transition hover:bg-emerald-400"
          >Back home</a
        >
        <a
          href="/tools"
          class="rounded-xl border-2 border-ink-700 px-5 py-2.5 font-semibold text-ink-100 transition hover:border-emerald-500"
          >All tools</a
        >
        <a
          href="/compare"
          class="rounded-xl border-2 border-ink-700 px-5 py-2.5 font-semibold text-ink-100 transition hover:border-emerald-500"
          >Compare tools</a
        >
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    import * as THREE from "https://esm.sh/three@0.161.0";

    const canvas = document.getElementById("shark-canvas");
    const stage = document.getElementById("shark-stage");
    const fallback = document.getElementById("shark-fallback");

    if (canvas && stage) {
      try {
        const renderer = new THREE.WebGLRenderer({
          canvas,
          alpha: true,
          antialias: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
        camera.position.set(0, 0.4, 7.6);
        camera.lookAt(0, 0, 0);

        scene.add(new THREE.AmbientLight(0x6b7686, 0.75));
        const key = new THREE.DirectionalLight(0xffffff, 1.15);
        key.position.set(4, 6, 6);
        scene.add(key);
        const rim = new THREE.DirectionalLight(0x16c95a, 0.9);
        rim.position.set(-6, 1, 2);
        scene.add(rim);

        const skin = new THREE.MeshStandardMaterial({
          color: 0x5b6675,
          roughness: 0.62,
          metalness: 0.15,
        });
        const dark = new THREE.MeshStandardMaterial({
          color: 0x10141a,
          roughness: 0.5,
        });

        const shark = new THREE.Group();

        const body = new THREE.Mesh(new THREE.SphereGeometry(1, 44, 30), skin);
        body.scale.set(2.6, 0.96, 0.92);
        shark.add(body);

        const snout = new THREE.Mesh(new THREE.ConeGeometry(0.62, 1.6, 32), skin);
        snout.rotation.z = -Math.PI / 2;
        snout.position.x = 2.55;
        shark.add(snout);

        // tail (caudal fin) as its own group so it can wag
        const tail = new THREE.Group();
        tail.position.x = -2.5;
        const upper = new THREE.Mesh(new THREE.ConeGeometry(0.5, 1.8, 4), skin);
        upper.scale.set(1, 1, 0.16);
        upper.rotation.z = -0.55;
        upper.position.set(-0.35, 0.72, 0);
        tail.add(upper);
        const lower = new THREE.Mesh(new THREE.ConeGeometry(0.42, 1.25, 4), skin);
        lower.scale.set(1, 1, 0.16);
        lower.rotation.z = Math.PI + 0.55;
        lower.position.set(-0.28, -0.52, 0);
        tail.add(lower);
        shark.add(tail);

        const dorsal = new THREE.Mesh(new THREE.ConeGeometry(0.62, 1.5, 4), skin);
        dorsal.scale.set(1, 1, 0.16);
        dorsal.rotation.z = -0.5;
        dorsal.position.set(-0.1, 1.05, 0);
        shark.add(dorsal);

        const pec1 = new THREE.Mesh(new THREE.ConeGeometry(0.44, 1.3, 4), skin);
        pec1.scale.set(1, 1, 0.14);
        pec1.position.set(0.95, -0.42, 0.55);
        pec1.rotation.set(0.5, 0.2, -1.95);
        shark.add(pec1);
        const pec2 = pec1.clone();
        pec2.position.z = -0.55;
        pec2.rotation.set(-0.5, -0.2, -1.95);
        shark.add(pec2);

        const eyeGeo = new THREE.SphereGeometry(0.11, 16, 16);
        const eye1 = new THREE.Mesh(eyeGeo, dark);
        eye1.position.set(2.0, 0.3, 0.52);
        shark.add(eye1);
        const eye2 = new THREE.Mesh(eyeGeo, dark);
        eye2.position.set(2.0, 0.3, -0.52);
        shark.add(eye2);

        const mouth = new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.09, 1.2), dark);
        mouth.position.set(2.15, -0.3, 0);
        mouth.rotation.z = 0.13;
        shark.add(mouth);

        shark.rotation.y = -0.6;
        scene.add(shark);

        let mx = 0,
          my = 0;
        window.addEventListener("pointermove", (e) => {
          mx = e.clientX / window.innerWidth - 0.5;
          my = e.clientY / window.innerHeight - 0.5;
        });

        function resize() {
          const w = stage.clientWidth,
            h = stage.clientHeight;
          renderer.setSize(w, h, false);
          camera.aspect = w / h;
          camera.updateProjectionMatrix();
        }
        resize();
        window.addEventListener("resize", resize);

        const clock = new THREE.Clock();
        let first = true;
        function tick() {
          const t = clock.getElapsedTime();
          shark.position.y = Math.sin(t * 1.1) * 0.18;
          shark.rotation.y = -0.6 + Math.sin(t * 0.5) * 0.25 + mx * 0.5;
          shark.rotation.z = Math.sin(t * 0.8) * 0.05;
          shark.rotation.x = my * 0.3;
          tail.rotation.y = Math.sin(t * 4) * 0.35;
          renderer.render(scene, camera);
          if (first) {
            first = false;
            if (fallback) fallback.style.display = "none";
          }
          requestAnimationFrame(tick);
        }
        tick();
      } catch (e) {
        console.warn("shark 3D unavailable, keeping fallback", e);
      }
    }
  </script>
</Base>
