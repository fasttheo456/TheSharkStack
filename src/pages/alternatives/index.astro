---
import Base from "../../layouts/Base.astro";
import ToolBadge from "../../components/ToolBadge.astro";
import { tools, categoryName } from "../../data/tools";

const sorted = [...tools].sort((a, b) => a.name.localeCompare(b.name));
---

<Base
  title="Software Alternatives"
  description="Looking for an alternative? Find the best alternatives to every B2B sales SaaS tool in our directory."
>
  <section class="border-b border-ink-100 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h1 class="text-4xl font-semibold text-ink-900 sm:text-5xl">
        Alternatives
      </h1>
      <p class="mt-3 max-w-2xl text-ink-500">
        Outgrowing a tool, or just weighing your options? Pick a product to see
        the strongest alternatives in the same category.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        sorted.map((t) => (
          <a
            href={`/alternatives/${t.slug}`}
            class="group flex items-center gap-3 rounded-2xl border border-ink-100 bg-white p-5 transition hover:border-brand-300 hover:shadow-lg hover:shadow-brand-500/5"
          >
            <ToolBadge badge={t.badge} website={t.website} name={t.name} size="sm" />
            <div class="min-w-0 flex-1">
              <p class="truncate font-semibold text-ink-900 group-hover:text-brand-700">
                {t.name} alternatives
              </p>
              <p class="truncate text-xs text-ink-400">
                {categoryName(t.primaryCategory)}
              </p>
            </div>
            <span class="text-brand-600" aria-hidden="true">
              &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </section>
</Base>
