---
import {
  toolBySlug,
  featuresForCategory,
  formatStartingPrice,
} from "../data/tools";
import ToolBadge from "./ToolBadge.astro";
import G2Link from "./G2Link.astro";

interface Props {
  slug: string;
  rank?: number;
}
const { slug, rank } = Astro.props;
const t = toolBySlug(slug);
const features = t
  ? featuresForCategory(t.primaryCategory)
      .filter((f) => t.features[f.key])
      .slice(0, 6)
  : [];
---

{
  t && (
    <div class="not-prose scroll-mt-24 rounded-2xl border border-ink-200 bg-white p-6 sm:p-7">
      <div class="flex items-start gap-4">
        <ToolBadge badge={t.badge} website={t.website} name={t.name} size="md" />
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-center gap-x-2.5 gap-y-1">
            {rank && (
              <span class="rounded-md bg-emerald-500 px-1.5 py-0.5 text-xs font-bold text-ink-900">
                #{rank}
              </span>
            )}
            <h3 class="text-xl font-bold text-ink-900">{t.name}</h3>
          </div>
          <p class="mt-0.5 text-sm text-ink-500">{t.tagline}</p>
        </div>
        <div class="hidden flex-shrink-0 sm:block">
          <G2Link name={t.name} />
        </div>
      </div>

      <p class="mt-4 text-[15px] leading-relaxed text-ink-700">{t.bestFor}</p>

      <div class="mt-5 grid gap-5 rounded-xl bg-ink-50 p-5 sm:grid-cols-[190px_1fr]">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-wider text-ink-400">
            Pricing
          </p>
          <p class="mt-1 font-bold text-ink-900">{formatStartingPrice(t)}</p>
          <p class="mt-0.5 text-xs leading-relaxed text-ink-500">
            {t.pricingNote}
          </p>
        </div>
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-wider text-ink-400">
            Key features
          </p>
          <ul class="mt-2 grid gap-x-4 gap-y-1.5 sm:grid-cols-2">
            {features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-ink-700">
                <svg
                  class="mt-0.5 h-4 w-4 flex-shrink-0 text-emerald-600"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 10.5l4 4 8-9" />
                </svg>
                {f.label}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href={t.website}
          target="_blank"
          rel="noopener nofollow"
          class="rounded-xl bg-emerald-500 px-5 py-2.5 text-sm font-bold text-ink-900 transition hover:bg-emerald-400"
        >
          Visit {t.name.split(" ")[0]} &rarr;
        </a>
        <a
          href={`/tools/${t.slug}`}
          class="rounded-xl border border-ink-300 px-5 py-2.5 text-sm font-semibold text-ink-700 transition hover:border-ink-900 hover:text-ink-900"
        >
          Full review
        </a>
      </div>
    </div>
  )
}
