---
import type { Tool } from "../data/tool-types";
import {
  categoryName,
  formatStartingPrice,
  featuresForCategory,
} from "../data/tools";
import { featureBlurbs } from "../data/feature-blurbs";

interface Props {
  tool: Tool;
}
const { tool } = Astro.props;

const first = tool.name.split(" ")[0];
const primaryCat = categoryName(tool.primaryCategory).toLowerCase();
const otherCats = tool.categories
  .filter((c) => c !== tool.primaryCategory)
  .map((c) => categoryName(c).toLowerCase());

const activeFeatures = featuresForCategory(tool.primaryCategory).filter(
  (f) => tool.features[f.key],
);

const teamMap: Record<string, string> = {
  solo: "solo founders and individual reps",
  startup: "startups",
  midmarket: "mid-market teams",
  enterprise: "enterprises",
};
const teams = tool.teamFit.map((t) => teamMap[t] ?? t);
const teamsText =
  teams.length <= 1
    ? teams[0]
    : `${teams.slice(0, -1).join(", ")} and ${teams[teams.length - 1]}`;

const complexityMap: Record<string, string> = {
  beginner: "easy to get started with",
  intermediate: "approachable, with a short learning curve",
  advanced: "powerful, with a steeper learning curve",
};
const budgetValueMap: Record<string, string> = {
  budget: "sits at the affordable end of the market",
  mid: "is mid-priced for the value it delivers",
  premium: "is a premium, higher-priced option",
};

const price = formatStartingPrice(tool);
const notFor =
  tool.budgetTier === "premium"
    ? `Smaller teams on a tight budget may find it more than they need`
    : tool.complexity === "advanced"
      ? `Teams that want a plug-and-play tool may prefer something lighter`
      : `It may be more than solo users with very basic needs require`;

const categoryUseCases: Record<string, string> = {
  prospecting:
    "Most teams use a prospecting tool at the very top of the funnel: a rep defines an ideal-customer profile, builds a list of matching companies and people, and enriches it with verified emails and direct dials before a single message goes out. The quality of this step sets the ceiling for everything downstream, no sequence or dialer can rescue a list built on bad data.",
  "sales-engagement":
    "In day-to-day use, a sales engagement tool is where reps actually run their outbound. They load prospects into multistep sequences, let the system schedule emails and surface call and LinkedIn tasks, and work a single prioritized to-do list each morning. Managers use it to standardize the motion so every rep follows the playbook that books meetings.",
  crm:
    "The CRM is the system of record the rest of the stack revolves around. Reps live in it to manage deals and log activity, managers use it to forecast and run one-on-ones, and every other sales tool ultimately reads from or writes to it. Getting the CRM right is what keeps pipeline data trustworthy.",
  "phone-system":
    "Teams reach for a sales phone system when calling is a core motion. Reps work through call lists with a dialer, use local numbers to lift pickup rates, and rely on automatic logging so every conversation lands in the CRM. The goal is simple: more live conversations per rep per day, with less manual busywork around each one.",
  "conversation-intelligence":
    "Conversation intelligence runs quietly in the background of every call and meeting, recording and transcribing automatically. Reps use it to skip note-taking, managers use the call library and analytics to coach, and leadership uses deal and risk signals to forecast more honestly. Over time it turns every conversation into reusable training material.",
  scheduling:
    "A scheduling tool removes the friction between interest and a booked meeting. For outbound, reps drop a personal booking link into emails so prospects self-serve a time; for inbound, the tool qualifies and routes web leads to the right rep instantly. Either way, the win is capturing buyer intent before it cools.",
  "sales-intelligence":
    "Sales intelligence sits one layer above raw contact data, telling reps not just who to contact but who is worth contacting now and why. Teams use it to score accounts against their ICP, watch for triggers like job changes and funding, and arrive at every conversation already briefed. It turns a flat list into a prioritized, timed plan.",
};

const categoryPersonas: Record<string, string> = {
  prospecting:
    "Typical users include SDRs building their daily call and email lists, RevOps teams enriching and de-duplicating the CRM, and founders doing their own outbound before a sales team exists.",
  "sales-engagement":
    "Typical users include SDR and BDR teams running outbound at volume, account executives managing follow-up across many open deals, and sales leaders enforcing a consistent cadence across the team.",
  crm:
    "Typical users include account executives managing pipeline day to day, sales managers running forecasts and coaching, and RevOps owning process, automation, and reporting.",
  "phone-system":
    "Typical users include high-activity SDR teams dialing all day, inside-sales reps who close over the phone, and support or success teams that need calling wired into the CRM.",
  "conversation-intelligence":
    "Typical users include front-line reps who want their notes written for them, sales managers coaching from real calls, and revenue leaders tracking deal risk across the pipeline.",
  scheduling:
    "Typical users include AEs sharing booking links to cut scheduling friction, demand-gen teams routing inbound demo requests, and customer teams booking onboarding and review calls.",
  "sales-intelligence":
    "Typical users include RevOps and growth teams building signal-based plays, AEs researching accounts before outreach, and marketing teams running account-based programs.",
};

const useCase = categoryUseCases[tool.primaryCategory] ?? "";
const personas = categoryPersonas[tool.primaryCategory] ?? "";

const lc = (s: string) => s.charAt(0).toLowerCase() + s.slice(1);
const strip = (s: string) => lc(s.replace(/\.$/, ""));
const bestForLc = lc(tool.bestFor.replace(/\.$/, ""));
const taglineLc = lc(tool.tagline);
---

<div class="space-y-12">
  <!-- Overview -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">Overview</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      {tool.description}
    </p>
    <p class="mt-4 text-[15px] leading-[1.8] text-ink-700">
      Founded in {tool.founded} and based in {tool.hq}, {first} competes in the{
        " "
      }{primaryCat} category{
        otherCats.length > 0
          ? `, with overlap into ${otherCats.join(" and ")}`
          : ""
      }. It is {complexityMap[tool.complexity]}, and it {
        budgetValueMap[tool.budgetTier]
      } ({price}). In practice, {first} is best for {bestForLc}.
    </p>
    {
      useCase && (
        <p class="mt-4 text-[15px] leading-[1.8] text-ink-700">{useCase}</p>
      )
    }
  </section>

  <!-- Key features -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">Key features</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      Here is what {first} brings to the table, and what each capability means in
      practice.
    </p>
    <div class="mt-6 space-y-5">
      {
        activeFeatures.map((f) => (
          <div>
            <p class="font-semibold text-ink-900">{f.label}</p>
            <p class="mt-1 text-[15px] leading-[1.7] text-ink-600">
              {featureBlurbs[f.key] ??
                `${first} supports ${f.label.toLowerCase()}.`}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Who it's for -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">Who it's for</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      {tool.name} is built for {teamsText}. It is a particularly strong fit for{" "}
      {bestForLc}, and reps will find it {complexityMap[tool.complexity]}.
    </p>
    <p class="mt-4 text-[15px] leading-[1.8] text-ink-700">
      It is less of a fit in a few cases. {notFor}, and if {
        lc(tool.cons[0].replace(/\.$/, ""))
      } is a dealbreaker for you, it is worth weighing against the alternatives
      before committing.
    </p>
    {
      personas && (
        <p class="mt-4 text-[15px] leading-[1.8] text-ink-700">{personas}</p>
      )
    }
  </section>

  <!-- Integrations & ecosystem -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">Integrations &amp; ecosystem</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      {first} connects with around {tool.integrationsCount}+ tools, including{" "}
      {tool.popularIntegrations.slice(0, -1).join(", ")} and {
        tool.popularIntegrations[tool.popularIntegrations.length - 1]
      }. That matters because a sales tool is only as useful as the rest of your
      stack: the tighter it plugs into your CRM and workflow, the less manual data
      entry your reps do and the cleaner your reporting stays.
    </p>
    {
      tool.features.apiAccess && (
        <p class="mt-4 text-[15px] leading-[1.8] text-ink-700">
          An open API and webhooks mean {first} can also be wired into custom
          workflows, internal dashboards, and the rest of your data stack, which
          is what RevOps teams look for when they want a tool to act as a building
          block rather than a silo.
        </p>
      )
    }
  </section>

  <!-- Pricing & value -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">Pricing &amp; value</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      {first} {budgetValueMap[tool.budgetTier]}. {tool.pricingNote}. The value
      case is strongest for the teams it is built for: when that is you, the time
      saved and meetings booked tend to outweigh the cost. If it is not, a lighter
      tool may serve you just as well for less. As always, the
      sticker price is only part of the story: weigh onboarding time, the tier
      your team will realistically land on, and any add-ons before comparing it
      against the alternatives.
    </p>
  </section>

  <!-- Strengths & limitations -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">Strengths &amp; limitations</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      On the strengths side, {first} stands out for a few reasons: {
        strip(tool.pros[0])
      }; {strip(tool.pros[1])}; and {strip(tool.pros[2])}.
    </p>
    <p class="mt-4 text-[15px] leading-[1.8] text-ink-700">
      The trade-offs are worth knowing before you commit: {strip(tool.cons[0])};{
        " "
      }{strip(tool.cons[1])}; and {strip(tool.cons[2])}. None of these are
      necessarily dealbreakers, but they are the points to pressure-test during a
      trial.
    </p>
  </section>

  <!-- Bottom line -->
  <section>
    <h2 class="text-xl font-bold text-ink-900">The bottom line</h2>
    <p class="mt-3 text-[15px] leading-[1.8] text-ink-700">
      {tool.name} delivers {taglineLc}, and it earns its place across {
        teamsText
      }. The standout reasons to pick it are clear, {
        lc(tool.pros[0].replace(/\.$/, ""))
      } chief among them, while the main thing to weigh is that {
        lc(tool.cons[0].replace(/\.$/, ""))
      }. If that trade-off fits your situation, {first} is well worth a trial.
    </p>
  </section>
</div>
