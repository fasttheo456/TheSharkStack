---
import type { Tool } from "../data/tools";
import { categoryName, formatStartingPrice } from "../data/tools";
import G2Link from "./G2Link.astro";
import ToolBadge from "./ToolBadge.astro";

interface Props {
  tool: Tool;
}
const { tool } = Astro.props;
---

<a
  href={`/tools/${tool.slug}`}
  class="group flex flex-col rounded-2xl border-2 border-ink-900 bg-white p-6 shadow-hard transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-hard-green"
>
  <div class="flex items-start gap-3">
    <ToolBadge badge={tool.badge} website={tool.website} name={tool.name} />
    <div class="flex min-h-12 min-w-0 flex-1 items-center">
      <h3
        class="truncate font-display text-lg uppercase tracking-wide text-ink-900 group-hover:text-orange-600"
      >
        {tool.name}
      </h3>
    </div>
  </div>

  <p class="mt-3 line-clamp-2 text-sm text-ink-500">{tool.tagline}</p>

  <div class="mt-3 flex flex-wrap gap-1.5">
    {
      tool.categories
        .slice(0, 2)
        .map((c) => (
          <span class="rounded-full border border-ink-900 bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-ink-900">
            {categoryName(c)}
          </span>
        ))
    }
    {
      tool.categories.length > 2 && (
        <span class="rounded-full border border-ink-900 bg-white px-2 py-0.5 text-xs font-semibold text-ink-700">
          +{tool.categories.length - 2}
        </span>
      )
    }
  </div>

  <div class="mt-4 flex items-center justify-between">
    <G2Link name={tool.name} />
  </div>

  <div
    class="mt-4 flex items-center justify-between border-t border-ink-100 pt-4"
  >
    <div>
      <span class="text-xs text-ink-400">From</span>
      <p class="font-semibold text-ink-900">{formatStartingPrice(tool)}</p>
    </div>
    <span
      class="text-sm font-medium text-ink-400 transition-transform group-hover:translate-x-0.5 group-hover:text-orange-600"
    >
      View &rarr;
    </span>
  </div>
</a>
