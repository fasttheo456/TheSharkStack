---
interface Props {
  class?: string;
  /** unique suffix so gradient/filter/clip ids don't clash across instances */
  uid?: string;
}
const { class: className = "h-8 w-8", uid = "lg" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="TheSharkStack"
>
  <!-- badge -->
  <rect x="0.5" y="0.5" width="31" height="31" rx="8" fill="#0F1318" stroke="#0F1318" />

  <!-- dorsal fin slicing forward -->
  <path
    d="M7.5 21 C10.5 14, 14.5 8.6, 21.4 6.6 C19.9 12, 21.4 16.8, 24.4 21 Z"
    fill="#FFFFFF"
  />

  <!-- waterline, emerald accent -->
  <g stroke="#16C95A" stroke-linecap="round" fill="none">
    <path
      d="M4 21.4 q2.6 -2.1 5.2 0 t5.2 0 t5.2 0 t5.2 0 t3 0"
      stroke-width="2"
      opacity="1"
    />
    <path
      d="M6 25.3 q2.6 -2 5.2 0 t5.2 0 t5.2 0 t3.4 0"
      stroke-width="1.6"
      opacity="0.6"
    />
  </g>
</svg>
